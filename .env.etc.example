# ===================================================
# Ethereum Classic (ETC) Testnet Configuration
# ===================================================
# Copy this file to .env and fill in your actual values
#
# IMPORTANT: This is for TESTNET ONLY!
# Never use mainnet addresses or private keys
# ===================================================

# === Database Configuration ===
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# === Tatum ETC Testnet Configuration ===
# Tatum API key for ETC testnet access
TATUM_ETC_TESTNET_API_KEY=your_tatum_api_key_here

# ETC testnet HOT wallet address (swept FROM)
# Format: 0x followed by 40 hex characters
# Example: 0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
TATUM_ETC_HOT_ADDRESS=0x...

# ETC testnet HOT wallet private key
# Format: 64 hex characters (without 0x prefix) or with 0x prefix
# KEEP THIS SECRET! Never commit to git
TATUM_ETC_HOT_PRIVATE_KEY=your_private_key_here

# ETC testnet COLD wallet address (swept TO)
# This is your secure storage address
TATUM_ETC_COLD_ADDRESS=0x...

# Minimum ETC balance required before sweeping (in ETC)
# Default: 1.0 ETC
TATUM_ETC_MIN_SWEEP=1.0

# Reserve ETC amount to keep in hot wallet for gas fees (in ETC)
# Default: 0.5 ETC
TATUM_ETC_RESERVE=0.5

# Base URL for Tatum ETC testnet (usually no need to change)
TATUM_ETC_BASE_URL=https://ethereum-classic-testnet.gateway.tatum.io

# ===================================================
# ETC Sweep Configuration
# ===================================================
# Enable one-shot sweep on startup
ETC_SWEEP_ON_STARTUP=false

# Enable periodic sweeping
ETC_SWEEP_PERIODIC_ENABLED=true

# Sweep every 15 seconds (15000 ms)
ETC_SWEEP_FIXED_DELAY_MS=15000

# Initial delay before first sweep (15 seconds)
ETC_SWEEP_INITIAL_DELAY_MS=15000

# ===================================================
# Getting ETC Testnet Tokens
# ===================================================
# To get testnet ETC:
# 1. Create a testnet wallet (use MetaMask or similar)
# 2. Get your testnet address (0x...)
# 3. Visit ETC testnet faucets:
#    - https://www.etctestnetfaucet.com/
#    - https://faucet.mordor.blockscout.com/
# 4. Enter your address to receive free testnet ETC
# ===================================================
